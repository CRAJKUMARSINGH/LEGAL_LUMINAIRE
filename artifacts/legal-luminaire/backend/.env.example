# Copy this to .env and fill in your keys
# NEVER commit .env to git

# Required: OpenAI API key (for GPT-4o agents + embeddings)
OPENAI_API_KEY=sk-...

# Required: Tavily API key (for real-time web verification of citations)
# Get free key at: https://tavily.com
TAVILY_API_KEY=tvly-...

# Optional: Serper API key (fallback web search)
SERPER_API_KEY=

# Optional: Google Gemini API key (for Omni-Modal case ingestion)
# Get free key at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# ── Live legal database APIs (optional — falls back to Tavily search) ──────────
# SCC Online API key — contact scconline.com for access
SCC_ONLINE_API_KEY=

# Manupatra API key — contact manupatra.com for API access
MANUPATRA_API_KEY=

# ChromaDB persistence path (local folder)
CHROMA_PERSIST_DIR=./chroma_db

# Case documents folder
CASE_DOCS_DIR=./uploaded_cases

# API settings
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Model settings
LLM_MODEL=gpt-4o
LLM_TEMPERATURE_RESEARCH=0.0
LLM_TEMPERATURE_DRAFT=0.2

# ── Embedding settings ─────────────────────────────────────────────────────────
# OpenAI embeddings (used if sentence-transformers not installed)
EMBEDDING_MODEL=text-embedding-3-small

# SBERT / GTE-Large local embeddings (no API cost, runs on CPU)
# Supported: thenlper/gte-large | sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_MODEL_LOCAL=thenlper/gte-large

# Rate limiting
MAX_REQUESTS_PER_MINUTE=10
MAX_TOKENS_PER_REQUEST=8000

# Hallucination circuit breaker threshold (0.0-1.0; default 0.25 = block if >25% ungrounded)
HALLUCINATION_THRESHOLD=0.25

