━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
CLAIM NO. 1 – COMPENSATION FOR DELAY IN SITE HANDOVER
AMOUNT: ₹4.82 CRORE | FACT-FIT SCORE: 94% | STATUS: VERIFIED
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

Facts:
- Work Order dated 05.05.2024; site handover required within 15 days (by 20.05.2024).
- Actual possession given on 20.05.2024 — after a delay of 45 days.
- Delay caused due to pending municipal NOC and existing structure demolition by RMSCL.
- Claimant had mobilized full team, machinery, and materials by 10.05.2024.

Clauses Relied Upon: GCC Clause 5 (Site Possession), Clause 10CC (Price Escalation)
FIDIC Sub-Clause 2.1 (Right of Access to Site for reference)

Calculation:
- Monthly establishment cost: ₹72 Lakh × 1.5 months       = ₹1.08 Cr
- Idle plant & machinery (concrete mixer, JCB, scaffolding): ₹1.84 Cr
- Labour idling cost (150 men × ₹450/day × 45 days)        = ₹30.38 Lakh
- Lost productivity (18% on ₹8 Cr work suppressed)         = ₹1.44 Cr
- Site overhead during idle period                          = ₹15.62 Lakh
TOTAL CLAIM 1: ₹4.82 Crore

Evidence:
1. Work Order RMSCL/2024-25/Works/4782 dated 05.05.2024
2. Site Possession Certificate dated 20.05.2024 (shows actual handover date)
3. Mobilization report dated 10.05.2024
4. Photographs of idle machinery (dated 10-20 May 2024)
5. Contractor's letters dated 11.05.2024, 15.05.2024, 18.05.2024 demanding possession
6. Labour register extracts for May 2024

Verified Precedents:
- K.N. Sathyapalan v. State of Kerala — SC upheld idle cost claims for delayed possession
- Tarapore & Co. v. Steel Authority of India — employer's possession delay = compensable
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
