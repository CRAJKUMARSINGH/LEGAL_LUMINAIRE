━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
II. SUBMISSION I — FOUNDATIONAL SCIENTIFIC ERROR: INAPPLICABILITY OF IS 1199:2018
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

The prosecution's entire case fails on the very first page of the FSL report. The
analyst has purportedly based the testing results on **IS 1199:2018**. This is
a fatal scientific error that voids the report *ab initio*.

1. **Category Mismatch**: IS 1199:2018 is titled "Methods of Sampling and
   Analysis of **Fresh Concrete**." Its scope (Clause 1) is strictly limited to
   concrete in its plastic/fresh state, before it has set and hardened. 

2. **Material Mismatch**: The samples in the present case were taken from the
   joints of an **existing stone masonry wall** that had been in place for
   several years. The material is **Hardened Cement Mortar**, not concrete. 

3. **Technical Impossibility**: Applying "Fresh Concrete" standards to "Hardened
   Masonry Mortar" is scientifically equivalent to applying "Liquid Milk" testing
   standards to "Hardened Cheese." The chemical and physical properties (pH,
   leachability, carbonation, hydration state) are fundamentally different.

4. **Correct Standards**:
   - For **Masonry Mortar**, the governing Indian Standard is **IS 2250:1981**
     ("Code of Practice for Preparation and Use of Masonry Mortars").
   - For **Hardened Mortar Analysis**, the globally accepted forensic standard
     equivalent to Section 45 IEA (Expert Opinion) is **ASTM C1324** ("Standard
     Test Method for Examination and Analysis of Hardened Masonry Mortar").

The prosecution has chosen the wrong "yardstick." If the measuring tool is wrong,
the measurement is irrelevant. In **State of Maharashtra v. Damu (2000) 6 SCC 269**,
the Hon'ble Supreme Court held that where the foundational facts/methods of an
expert opinion are unreliable, the opinion is of no value.

