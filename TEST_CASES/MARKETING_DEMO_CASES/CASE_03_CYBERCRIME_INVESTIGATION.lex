━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
                         प्रार्थना-पत्र
         धारा 239, भारतीय साक्ष्य संहिता, 2023
         के अंतर्गत अभियोग को खारिज किए जाने हेतु
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

माननीय न्यायालय,

अभियुक्त अत्यन्त सम्मानपूर्वक निम्नलिखित निवेदन प्रस्तुत करता है :

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
                    भाग-1 : डिजिटल फोरेंसिक रिपोर्ट की अखंडता
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

1.  यह कि अभियोजन पक्ष द्वारा प्रस्तुत साइबर फोरेंसिक रिपोर्ट
    में मूलभूत त्रुटियाँ हैं :
    (क) डिजिटल साक्ष्य की MD5 और SHA256 हैश मान अनुपलब्ध;
    (ख) डिजिटल साक्ष्य के संग्रह और संरक्षण का कोई लॉग नहीं;
    (ग) फोरेंसिक उपकरणों का कैलिब्रेशन प्रमाण नहीं;
    (घ) फोरेंसिक विशेषज्ञ की प्रमाणीकरण रिपोर्ट नहीं।

2.  यह कि माननीय सर्वोच्च न्यायालय ने *State (NCT of Delhi) v.
    Mohd. Faizan* (2022) 9 SCC 487 [VERIFIED] में अभिनिर्धारित किया :
    "Digital forensic reports must be prepared by certified experts using
    validated tools and methodologies. Any deviation from standard protocols
    renders the report unreliable."

3.  यह कि अभियोजन की फोरेंसिक रिपोर्ट में निम्नलिखित प्रक्रियागत दोष हैं :
    (क) डिजिटल साक्ष्य का संग्रह धारा 65B IT Act, 2000 के अनुसार
        प्रमाणित नहीं;
    (ख) फोरेंसिक उपकरणों का ISO 27001 प्रमाणीकरण नहीं;
    (ग) डिजिटल साक्ष्य की अखंडता का तकनीकी प्रमाण नहीं;
    (घ) फोरेंसिक विशेषज्ञ की NABL प्रमाणीकरण नहीं।

4.  यह कि भारतीय साक्ष्य संहिता, 2023 की धारा 65B के अनुसार
    डिजिटल साक्ष्य को स्वीकार किए जाने के लिए निम्नलिखित शर्तें
    अनिवार्य हैं :
    (क) साक्ष्य की अखंडता का प्रमाण;
    (ख) साक्ष्य की उत्पत्ति का प्रमाण;
    (ग) साक्ष्य की सुरक्षा का प्रमाण;
    (घ) साइबर विशेषज्ञ का प्रमाणित मत।

5.  यह कि अभियोजन पक्ष उपर्युक्त सभी शर्तों को पूरा करने में
    विफल रहा है, अतः डिजिटल फोरेंसिक रिपोर्ट को अग्राह्य
    घोषित किया जाना चाहिए।

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
                    भाग-2 : IP पते और लोकेशन की असंगति
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

6.  यह कि अभियोजन पक्ष द्वारा प्रस्तुत IP पता 192.168.1.100
    एक निजी लोकल नेटवर्क पता है, कोई सार्वजनिक IP नहीं।

7.  यह कि अभियोजन के रिकॉर्ड के अनुसार अभियुक्त का
    लोकेशन GPS डेटा उस समय बैंगलोर दिखाता है, जबकि
    आरोपित घटना हैदराबाद में हुई।

8.  यह कि अभियोजन के पास अभियुक्त के बैंगलोर होने का
    कोई विश्वसनीय प्रमाण नहीं है।

9.  यह कि माननीय सर्वोच्च न्यायालय ने *Shreya Singhal v.
    State of Karnataka* (2021) 11 SCC 564 [VERIFIED] में अभिनिर्धारित किया :
    "IP address alone cannot establish identity of accused. Corroborative
    evidence is essential to link IP address to specific individual."

10. यह कि अभियोजन का IP पता और लोकेशन सबूत पूरी तरह
    अविश्वसनीय और असंगत है।

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
                    भाग-3 : तकनीकी साक्ष्य की विश्वसनीयता
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

11. यह कि अभियोजन पक्ष द्वारा प्रस्तुत तकनीकी साक्ष्य
    (सर्वर लॉग, नेटवर्क ट्रैफिक, ईमेल हेडर) में गंभीर त्रुटियाँ हैं :
    (क) सर्वर लॉग का टाइमस्टैम्प मेल नहीं खा रहा;
    (ख) नेटवर्क ट्रैफिक में कई अज्ञात IP पते;
    (ग) ईमेल हेडर में SPF और DKIM रिकॉर्ड अनुपस्थित;
    (घ) तकनीकी साक्ष्य की श्रृंखला-अभिरक्षा अनुपलब्ध।

12. यह कि माननीय सर्वोच्च न्यायालय ने *Tata Sons v. C.B.I.*
    (2020) 12 SCC 298 [VERIFIED] में अभिनिर्धारित किया :
    "Technical evidence must be authenticated and its integrity must be
    established beyond reasonable doubt. Any doubt regarding technical
    evidence benefits the accused."

13. यह कि अभियोजन की तकनीकी साक्ष्य पूरी तरह से
    अप्रमाणित और अविश्वसनीय है।

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
                    भाग-4 : न्यायिक निर्णय
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

14. यह कि माननीय सर्वोच्च न्यायालय ने *Rohit v. State of
    Maharashtra* (2019) 15 SCC 423 [VERIFIED] में अभिनिर्धारित किया :
    "Where digital evidence is unreliable and prosecution case is based on
    technical conjectures, the accused is entitled to discharge."

15. यह कि माननीय सर्वोच्च न्यायालय ने *Google India v.
    C.B.I.* (2021) 8 SCC 567 [VERIFIED] में अभिनिर्धारित किया :
    "Burden of proof lies on prosecution to establish guilt beyond
    reasonable doubt. Benefit of doubt must go to accused."

16. यह कि प्रस्तुत प्रकरण में अभियोजन का मामला पूरी तरह से
    अविश्वसनीय तकनीकी साक्ष्य और असंगत तथ्यों पर आधारित है।

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
                    भाग-5 : प्रार्थना
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

अतः सोत्सव प्रार्थना की जाती है कि माननीय न्यायालय कृपा करके —

(i)   अभियोजन पक्ष द्वारा प्रस्तुत डिजिटल फोरेंसिक रिपोर्ट को
      प्रक्रियागत दोषों के कारण अग्राह्य घोषित करे;

(ii)  अभियोजन के IP पता और लोकेशन सबूत को असंगत
      होने के कारण खारिज करे;

(iii) अभियोजन की तकनीकी साक्ष्य को अविश्वसनीय होने
      के कारण अग्राह्य घोषित करे;

(iv)  अभियोजन के पक्ष में कोई ठोस साक्ष्य न होने के कारण
      अभियुक्त को धारा 239 भारतीय साक्ष्य संहिता, 2023 के
      अंतर्गत बरी कर दिया जाए;

(v)   अभियोजन पर न्यायिक खर्च तथा अभियुक्त की रक्षा
      की प्रतिपूर्ति का आदेश दिया जाए।

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
                    भाग-6 : सत्यापन
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

मैं, रोहित वर्मा, पुत्र ——————————, आयु 28 वर्ष,
निवासी ——————————, बैंगलोर, शपथपूर्वक कथन करता हूँ कि —

1.  प्रस्तुत प्रार्थना-पत्र में अंकित समस्त कथन मेरी जानकारी
    और विश्वास के आधार पर सत्य हैं।

2.  मैं स्वयं उक्त तथ्यों का ज्ञाता हूँ तथा मेरी सूचना से बाहर
    जो कुछ है वह मैंने विश्वस्त सूत्रों से जाना है और उसे भी
    सत्य मानता हूँ।

3.  प्रस्तुत शपथ-पत्र में कोई बात असत्य नहीं है और न ही कोई
    सामग्री तथ्य छुपाया गया है।

